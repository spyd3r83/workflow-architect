{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|apply_patch|str_replace_editor",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/scripts/enforcement/dispatch-gate-hook.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^task$|^Agent$",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/scripts/enforcement/dispatch-gate-hook.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
