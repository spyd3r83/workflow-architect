{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "write|edit|bash|str_replace_editor|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-tool-use.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-compact.sh"
          }
        ]
      }
    ]
  }
}
